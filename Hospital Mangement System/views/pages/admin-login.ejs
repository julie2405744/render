<!DOCTYPE html>
<html lang="en">
<!-- ========================================================= -->
<!-- @Author: Member 2 (Database & Admin Manager)              -->
<!-- @Responsibility: Admin login gateway UI                   -->
<!-- ========================================================= -->
<head>
    <%- include('../partials/head', { title: 'Admin Login', extraCss: [] }) %>
    <style>
        .admin-login-wrap {
            display: flex; justify-content: center; align-items: center;
            min-height: calc(100vh - 60px); padding: 20px;
        }
        .admin-login-card { max-width: 400px; width: 100%; }
        .admin-login-header { text-align: center; margin-bottom: 24px; }
        .admin-login-header span { font-size: 2.4rem; display: block; margin-bottom: 10px; }
    </style>
</head>
<body>

    <%- include('../partials/navbar', { role: 'auth' }) %>

    <div class="app-wrap">
        <div class="admin-login-wrap">
            <div class="auth-card card admin-login-card">
                <div class="admin-login-header">
                    <span>🛡️</span>
                    <h2>Admin Portal</h2>
                    <p class="hint">Restricted access — authorized personnel only</p>
                </div>

                <% if (typeof error !== 'undefined' && error) { %>
                <div style="color:var(--red); background:rgba(232,64,64,0.08); border:1px solid rgba(232,64,64,0.2); border-radius:10px; padding:10px 14px; font-size:0.86rem; margin-bottom:14px;">
                    <%= error %>
                </div>
                <% } %>

                <form method="POST" action="/admin/login">
                    <div class="input-group">
                        <input type="text" name="username" placeholder="Username" required>
                    </div>
                    <div class="input-group">
                        <input type="password" name="password" placeholder="Password" required>
                    </div>
                    <button type="submit" class="btn-form">Login as Admin</button>
                </form>

                <p style="text-align:center; margin-top:16px;">
                    <a href="/" style="color:var(--subtle); font-size:0.82rem;">← Back to Site</a>
                </p>
            </div>
        </div>
    </div>

    <%- include('../partials/scripts', { extraScripts: [] }) %>

</body>
</html>
