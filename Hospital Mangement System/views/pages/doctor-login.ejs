<!DOCTYPE html>
<html lang="en">
<!-- ========================================================= -->
<!-- @Author: Member 5 (Interactive Operations Developer)      -->
<!-- @Responsibility: Doctor portal login interface            -->
<!-- ========================================================= -->
<head>
    <%- include('../partials/head', { title: 'Doctor Login', extraCss: [] }) %>
    <style>
        .login-wrap {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--bg);
        }
        .login-box {
            width: 100%;
            max-width: 400px;
            background: white;
            padding: 36px;
            border-radius: 16px;
            box-shadow: 0 8px 30px rgba(0,0,0,0.08);
        }
        .login-box h2 {
            text-align: center;
            margin-bottom: 6px;
            font-size: 1.4rem;
        }
        .login-box .subtitle {
            text-align: center;
            color: var(--subtle);
            font-size: 0.9rem;
            margin-bottom: 28px;
        }
        .login-box .input-group {
            margin-bottom: 14px;
        }
        .login-box select,
        .login-box input[type="password"] {
            width: 100%;
            padding: 11px 14px;
            border: 1px solid var(--border);
            border-radius: 10px;
            font-family: inherit;
            font-size: 0.95rem;
            background: white;
            box-sizing: border-box;
        }
        .error-msg {
            background: #fff1f1;
            color: #c0392b;
            border: 1px solid #f5c6cb;
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 0.88rem;
            margin-bottom: 16px;
            text-align: center;
        }
        .back-link {
            display: block;
            text-align: center;
            margin-top: 18px;
            font-size: 0.88rem;
            color: var(--subtle);
            text-decoration: none;
        }
        .back-link:hover { color: var(--accent); }
    </style>
</head>
<body>
    <div class="login-wrap">
        <div class="login-box">
            <h2>👨‍⚕️ Doctor Portal</h2>
            <p class="subtitle">Select your name and enter your password</p>

            <% if (error === 'invalid') { %>
                <div class="error-msg">Incorrect password. Please try again.</div>
            <% } else if (error === 'notfound') { %>
                <div class="error-msg">Doctor not found. Please select your name from the list.</div>
            <% } %>

            <% if (doctors.length === 0) { %>
                <div class="error-msg">No doctors have been registered yet. Please ask the admin to add doctors first.</div>
            <% } else { %>
                <form action="/doctor/login" method="POST">
                    <div class="input-group">
                        <select name="doctorName" required>
                            <option value="">Select Your Name</option>
                            <% doctors.forEach(function(d) { %>
                                <option value="<%= d.name %>"><%= d.name %></option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="input-group">
                        <input type="password" name="password" placeholder="Password" required>
                    </div>
                    <button type="submit" class="btn-form" style="width:100%;">Login</button>
                </form>
            <% } %>

            <a href="/" class="back-link">← Back to Home</a>
        </div>
    </div>
</body>
</html>
